{% doc %}
  @prompt
    {% comment %} Trust Badges Section {% endcomment %}
    
    <style>
      .trust-badges-section {
        background-color: {{ section.settings.background_color }};
        padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
      }
    
      .trust-badges-wrapper {
        max-width: {{ section.settings.max_width }}px;
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: {{ section.settings.gap }}px;
      }
    
      .trust-badge-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: {{ section.settings.icon_text_gap }}px;
        flex: 1 1 0;
        min-width: 120px;
      }
    
      .trust-badge-circle {
        width: {{ section.settings.circle_size }}px;
        height: {{ section.settings.circle_size }}px;
        border-radius: 50%;
        background-color: {{ section.settings.circle_color }};
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
    
      .trust-badge-circle svg {
        width: {{ section.settings.icon_size }}px;
        height: {{ section.settings.icon_size }}px;
        color: {{ section.settings.icon_color }};
        fill: none;
        stroke: currentColor;
        stroke-width: 1.5;
        stroke-linecap: round;
        stroke-linejoin: round;
      }
    
      .trust-badge-label {
        font-size: {{ section.settings.font_size }}px;
        font-weight: {{ section.settings.font_weight }};
        color: {{ section.settings.text_color }};
        letter-spacing: {{ section.settings.letter_spacing }}px;
        text-align: center;
        text-transform: uppercase;
        font-family: {{ section.settings.font_family }}, sans-serif;
      }
    
      /* Mobile: 2x2 grid */
      @media (max-width: 749px) {
        .trust-badges-wrapper {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: {{ section.settings.mobile_gap }}px;
        }
    
        .trust-badge-item {
          flex: unset;
        }
    
        .trust-badge-circle {
          width: {{ section.settings.circle_size_mobile }}px;
          height: {{ section.settings.circle_size_mobile }}px;
        }
    
        .trust-badge-label {
          font-size: {{ section.settings.font_size_mobile }}px;
        }
      }
    </style>
    
    <div class="trust-badges-section">
      <div class="trust-badges-wrapper">
    
        {% for block in section.blocks %}
          {% if block.settings.enabled %}
          <div class="trust-badge-item" {{ block.shopify_attributes }}>
            <div class="trust-badge-circle">
              {% case block.settings.icon %}
                {% when 'eco' %}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 22C6.5 22 2 17.5 2 12C2 6.5 6.5 2 12 2C17.5 2 22 6.5 22 12" stroke-width="1.5"/>
                    <path d="M13 8C13 8 8 9.5 8 15C8 15 11 13 14 14C17 15 18 18 18 18C18 18 20 13 18 10C16 7 13 8 13 8Z"/>
                    <path d="M8 15L12 19"/>
                  </svg>
                {% when 'shipping' %}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 3H16V16H1z"/>
                    <path d="M16 8H20L23 11V16H16V8Z"/>
                    <circle cx="5.5" cy="18.5" r="2.5"/>
                    <circle cx="18.5" cy="18.5" r="2.5"/>
                    <line x1="1" y1="6" x2="7" y2="6"/>
                    <line x1="1" y1="9" x2="5" y2="9"/>
                  </svg>
                {% when 'returns' %}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 2L3 6V20C3 21.1 3.9 22 5 22H19C20.1 22 21 21.1 21 20V6L18 2H6Z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <polyline points="12,8 12,16"/>
                    <polyline points="9,13 12,16 15,13"/>
                  </svg>
                {% when 'payment' %}
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <rect x="1" y="4" width="18" height="13" rx="2" ry="2"/>
                    <line x1="1" y1="10" x2="19" y2="10"/>
                    <path d="M16 17C16 14.8 17.8 13 20 13C22.2 13 24 14.8 24 17C24 19.2 22.2 21 20 21C17.8 21 16 19.2 16 17Z"/>
                    <polyline points="18.5,17 19.5,18 21.5,16"/>
                  </svg>
                {% when 'custom' %}
                  {% if block.settings.custom_svg != blank %}
                    {{ block.settings.custom_svg }}
                  {% endif %}
              {% endcase %}
            </div>
            <span class="trust-badge-label">{{ block.settings.label }}</span>
          </div>
          {% endif %}
        {% endfor %}
    
      </div>
    </div>
    
    {% schema %}
    {
      "name": "Trust Badges",
      "tag": "section",
      "class": "trust-badges",
      "settings": [
        {
          "type": "header",
